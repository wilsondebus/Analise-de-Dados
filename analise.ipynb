#Passo a passo do projeto 

#Passo 1: Abrir a base de dados (Importar a base de dados)
import pandas as pd #pacote para importar a base de dados (o "as pd" serve para colocar um apelido no pandas para não usar "pandas" toda vez de escrever)

tabela = pd.read_csv("cancelamentos.csv")   #armazena o arquico na variavel tabela 
display(tabela) #enves de usar o print, pode usar o display(que deixa a tabela mais visual)

#kaggle (site com varias base de dados para treinar)

#Passo 2: Vizualizar a base de dados 
    #Entender as informações disponiveis 
    #Possiveis prblemas/erros na base de dados 

#informações que não te ajudam te atrapalham 
#o ID do consumidor, NESSE CASO não serve para nada na analise
tabela = pd.read_csv("cancelamentos.csv")

tabela = tabela.drop(columns="CustomerID")  #remove a coluna CustomerID
display(tabela)

#Passo 3: Corrigir os problemas da base de dados (Tratamento de dados)
#Valores em formatos errados
#Informações vazias 

display(tabela.info())  #mostra as informações da tabela (a partir disso, excluir linhas que possuem informações vazias)

tabela = tabela.dropna()    #na = vazio = NaN - Not a Namber
display(tabela.info())

#Passo 4: Analise inicial (entender quantos clientes cancelaram)
#Antes de fazer a analise, é bom saber quantos clientes cancelaram(pra verificar se é necessario uma mudança)
#cancelou = 0 NÃO CANCELOU, cancelou = 1 CANCELOU   

print(tabela["cancelou"].value_counts())   #contar valores

print(tabela["cancelou"].value_counts(normalize=True))  #dizer o percentual

#Passo 5: Analise detalhads (entender o porque de cada cliente cancelou/como cadas coluna impacta no cancelamento)
#Usar grafico para ser melhor de analisar e apresentar(USAR GRAFICOS INTUITIVOS)    
import plotly.express as px #px é só para apelido 


for coluna in tabela.columns:   #para cada coluna dentro tabela 
    #cria grafico
    grafico = px.histogram(tabela, x=coluna, color="cancelou",text_auto=True)  #diferencia quem cancelou e quem não cancelou na duração de contrato
    grafico.show()  #exibe

